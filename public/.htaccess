<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^index\.html$ - [L]

  # 301 redirect legacy /windows to /windows-pvh
  RewriteRule ^windows/?$ /windows-pvh/ [R=301,L]

  # Pre-rendered routes (Apache; on nginx use docs/DEPLOY.md snippet)
  RewriteRule ^windows-pvh/?$ /windows-pvh/index.html [L]
  RewriteRule ^windows-alu/?$ /windows-alu/index.html [L]
  RewriteRule ^doors/?$ /doors/index.html [L]
  RewriteRule ^partitions/?$ /partitions/index.html [L]
  RewriteRule ^windowsills/?$ /windowsills/index.html [L]
  RewriteRule ^accessories/?$ /accessories/index.html [L]
  RewriteRule ^portfolio/?$ /portfolio/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
